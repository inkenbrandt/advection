[flake8]
# Match the Ruff/Black line length (88) rather than the pycodestyle default 79.
max-line-length = 88
# Black/Ruff-compatible relaxations:
#   E203 - whitespace before ':' (conflicts with Black slice formatting)
#   W503 - line break before binary operator (Black puts the operator first)
extend-ignore = E203, W503
per-file-ignores =
    # Public API is re-exported via star-imports (see ruff.toml).
    src/advection/__init__.py: F401, F403
exclude =
    .git,
    .venv,
    .tox,
    build,
    dist,
    docs,
    *.egg-info,
    __pycache__
